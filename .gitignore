# assets - comment to include downloaded libs into repository
www/assets/lib/*
!www/assets/lib/.gitkeep

php/vendor/*
!php/vendor/.gitkeep

# Local public DB/admin consoles and backups must not be staged.
www/ppm.php
www/web.config.bak

# Machine-local host configs must not be staged.
php/configs/*.lo.php

doc/
.idea/

docs/agents/artifacts/*
!docs/agents/artifacts/.gitkeep
docs/agents/local/*
!docs/agents/local/.gitkeep

upload/*
!upload/.gitkeep

# Log files
*.log

# Generated by Windows
Thumbs.db
